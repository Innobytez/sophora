PORT=3000
APP_URL=https://sophora.innobytez.com
NODE_ENV=production

DB_CLIENT=postgres
DATABASE_URL=postgresql://sophora:sophora@127.0.0.1:5432/sophora

STORAGE_DRIVER=s3
S3_BUCKET=sophora-local
S3_REGION=us-east-1
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=sophora
S3_SECRET_ACCESS_KEY=sophora-storage
S3_FORCE_PATH_STYLE=true

SESSION_SECRET=replace-with-a-long-random-string
APP_ENCRYPTION_KEY=replace-with-another-long-random-string

ADMIN_EMAIL=admin@innobytez.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Sophora <no-reply@innobytez.com>"
